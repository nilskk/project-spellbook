{
  "manifest_version": 3,
  "name": "Project Spellbook",
  "version": "1.0.0",
  "description": "Enhance the UI of D&D Beyond character tool",
  "permissions": [
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://dndbeyond.com/*",
    "*://www.dndbeyond.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://dndbeyond.com/characters/*",
        "*://www.dndbeyond.com/characters/*"
      ],
      "js": ["content.js"]
    }
  ]
}
